local M1AnimIds = {
    ['rbxassetid://10469493270'] = { CustomAnim = '17888704024', BodyPart = 'Right Arm' },
    ['rbxassetid://10469630950'] = { CustomAnim = '13532600125', BodyPart = 'Left Arm' },
