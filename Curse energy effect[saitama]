-- Spawn cursed energy arm effect on M1
local function SpawnCursedEnergyEffect(bodyPartName)
    local CursedEnergy = GojoAsset:FindFirstChild('CursedEnergy', true)
    if not CursedEnergy then return end

    local armEffect = CursedEnergy:FindFirstChild('Arm')
    if not armEffect then return end

    armEffect = armEffect:Clone()

    local bodyPart = Character:FindFirstChild(bodyPartName)
    if not (armEffect and bodyPart) then return end

    armEffect.Parent = workspace.Thrown

    local weld = Instance.new('Weld', armEffect)
    weld.Part0 = armEffect
    weld.Part1 = bodyPart

    -- Fade in particles/beams then fade out
    for _, v in pairs(armEffect:GetDescendants()) do
        if v:IsA('ParticleEmitter') then
            v.Enabled = true
            TweenService:Create(v, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Rate = 0}):Play()

        elseif v:IsA('Beam') then
            v.Enabled = true

            local nv0 = Instance.new('NumberValue', v)
            local nv1 = Instance.new('NumberValue', v)
            local nv2 = Instance.new('NumberValue', v)
            nv2.Value = 0.95

            nv0.Changed:Connect(function()
                v.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0,     1,         0),
                    NumberSequenceKeypoint.new(0.188, nv0.Value, 0),
                    NumberSequenceKeypoint.new(0.413, nv1.Value, 0),
                    NumberSequenceKeypoint.new(0.492, nv2.Value, 0),
                    NumberSequenceKeypoint.new(1,     1,         0),
                })
            end)

            TweenService:Create(nv0, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value = 1}):Play()
            TweenService:Create(nv1, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value = 1}):Play()
            TweenService:Create(nv2, TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Value = 1}):Play()
        end
    end

    game.Debris:AddItem(armEffect, 1.5)
end

-- Play hit effect on a target (light or heavy)
local function PlayHitEffect(targetRootPart, isHeavy)
    local Hit = GojoAsset:FindFirstChild('Hit', true)
    if not Hit then return end

    local hitType = isHeavy and Hit:FindFirstChild('Heavy') or Hit:FindFirstChild('Light')
    if not hitType then return end

    local hitClone = hitType:Clone()
    hitClone.Parent = workspace.Thrown
    hitClone.Anchored = false
    hitClone.CFrame = CFrame.new(targetRootPart.Position, HumanoidRootPart.Position)

    EmitAll(hitClone, 1)
    game.Debris:AddItem(hitClone, isHeavy and 2 or 0.6)
end

-- Black Flash visual burst on target
local function PlayBlackFlashEffect(targetRootPart, targetChar)
    local BlackFlashWhiff = GojoAsset:FindFirstChild('BlackFlashWhiff', true)
    if not BlackFlashWhiff then return end

    local whiffClone = GetAsset(BlackFlashWhiff, {
        Parent = workspace.Thrown,
        CFrame  = targetRootPart.CFrame,
    })

    EmitAll(whiffClone, 3)
    BlackFlashLightning(targetRootPart)
    game.Debris:AddItem(whiffClone, 3)

    -- Lightning wraps around victim's body parts
    local bodyPartNames = {'Torso','Left Arm','Right Arm','Left Leg','Right Leg','Head'}
    spawn(function()
        local folder = Instance.new('Folder', workspace)

        for _, partName in pairs(bodyPartNames) do
            local part = targetChar:FindFirstChild(partName)
            if part then
                local ghost = part:Clone()
                ghost.Parent = folder
                ghost.Transparency = 1
                ghost.CanCollide = false
                ghost.Anchored = false
                ghost:ClearAllChildren()

                local weld = Instance.new('Weld')
                weld.Part0 = ghost
                weld.Part1 = part
                weld.Parent = ghost
            end
        end

        game.Debris:AddItem(folder, 3)

        -- Ambient lightning around the folder
        local trove = Trove.new()
        local startTime = tick()

        while folder and folder:IsDescendantOf(game) and (tick() - startTime < 3) do
            task.wait(0.05)
            local parts = folder:GetChildren()
            if #parts == 0 then break end

            local fromPart = parts[RNG:NextInteger(1, #parts)]
            local toPart   = parts[RNG:NextInteger(1, #parts)]
            if fromPart == toPart then continue end

            local bolt, destroyFn = CreateLightningBolt({
                Start = fromPart.Position,
                End   = toPart.Position,
            })
            bolt.Thickness = 0.75
            bolt.MaxRadius = RNG:NextNumber(1.5, 8)
            bolt.PulseLength = 2
            bolt.PulseSpeed = 8
            bolt.Enabled = true

            trove:Add(function() destroyFn() end)
            task.delay(bolt.PulseLength + 0.5, destroyFn)
        end

        trove:Destroy()
    end)
end

-- ==================== DETECT HITS & APPLY EFFECTS ====================

local function WatchTarget(targetChar)
    local targetHumanoid = targetChar:WaitForChild('Humanoid', 1)
    local targetRoot     = targetChar:WaitForChild('HumanoidRootPart', 1)
    if not (targetHumanoid and targetRoot) then return end

    local prevHealth = targetHumanoid.Health

    if Connections[targetChar.Name] then
        Connections[targetChar.Name]:Disconnect()
    end

    Connections[targetChar.Name] = targetHumanoid:GetPropertyChangedSignal('Health'):Connect(function()
        -- Only react to hits from our character
        if targetChar:GetAttribute('LastHit') ~= Character.Name then
            prevHealth = targetHumanoid.Health
            return
        end

        local damage = prevHealth - targetHumanoid.Health
        if damage <= 0 then
            prevHealth = targetHumanoid.Health
            return
        end

        -- Determine which M1 animation is playing
        local isBlackFlash = IsAnimPlaying(Animator, '10466974800') 
                          or IsAnimPlaying(Animator, '10471336737')
        local isHeavy      = IsAnimPlaying(Animator, '13294471966') 
                          or IsAnimPlaying(Animator, '10470104242')
        local isSlam       = IsAnimPlaying(Animator, '12510170988')

        if targetHumanoid.Health > 0 then
            -- Normal M1 hit
            if damage > 1 then
                if isBlackFlash or isSlam then
                    PlayBlackFlashEffect(targetRoot, targetChar)
                elseif isHeavy then
                    PlayHitEffect(targetRoot, true)
                else
                    PlayHitEffect(targetRoot, false)
                end
            end
        else
            -- Kill blow with Black Flash
            if isBlackFlash then
                PlayBlackFlashEffect(targetRoot, targetChar)
            end
        end

        prevHealth = targetHumanoid.Health
    end)
end

-- ==================== HOOK ANIMATION FOR ARM EFFECT ====================

Connections['AnimationPlayed'] = Animator.AnimationPlayed:Connect(function(track)
    local animId = track.Animation.AnimationId
    local data   = M1AnimIds[animId]

    if data then
        SpawnCursedEnergyEffect(data.BodyPart)
    end
end)

-- ==================== WATCH ALL PLAYERS ====================

for _, player in pairs(Players:GetPlayers()) do
    if player.Character and player ~= LocalPlayer then
        WatchTarget(player.Character)
    end
    player.CharacterAdded:Connect(function(char)
        if player ~= LocalPlayer then
            WatchTarget(char)
        end
    end)
end

Players.PlayerAdded:Connect(function(player)
    player.CharacterAdded:Connect(function(char)
        if player ~= LocalPlayer then
            WatchTarget(char)
        end
    end)
end)

-- Watch workspace.Live if your game uses it
if workspace:FindFirstChild('Live') then
    Connections['LiveChildAdded'] = workspace.Live.ChildAdded:Connect(function(child)
        task.wait()
        WatchTarget(child)
    end)
end

