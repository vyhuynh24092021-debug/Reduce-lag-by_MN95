GojoAsset.Name = 'Gojo'

-- Config
local LightningColor = Color3.fromRGB(125, 0, 0)
local RNG = Random.new()

-- Connections table
local Connections = {}

-- ==================== UTILITY FUNCTIONS ====================

local function GetAsset(original, props)
    local clone = original:Clone()
    if props then
        for k, v in pairs(props) do
            clone[k] = v
        end
    end
    return clone
end

local function EmitAll(model, count)
    for _, v in pairs(model:GetDescendants()) do
        if v:IsA('ParticleEmitter') then
            local emitCount = v:GetAttribute('EmitCount') or count
            local emitDelay = v:GetAttribute('EmitDelay') or 0
            task.delay(emitDelay, function()
                v:Emit(emitCount)
            end)
        end
    end
end

local function EnableAllVisuals(model, enabled)
    for _, v in pairs(model:GetDescendants()) do
        if v:IsA('ParticleEmitter') or v:IsA('Trail') or v:IsA('Beam') then
            v.Enabled = enabled
        end
    end
end

local function IsAnimPlaying(animator, animId)
    animId = tostring(animId)
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
        if track.Animation.AnimationId:match(animId) then
            return track
        end
    end
end

-- ==================== LIGHTNING FUNCTIONS ====================

local function CreateLightningBolt(params)
    params = params or {}
    local startPos = params.Start or Vector3.zero
    local endPos = params.End or Vector3.zero
    local segments = params.Amount or 12

    local att0 = Instance.new('Attachment')
    att0.Position = startPos
    att0.Archivable = false
    att0.Parent = workspace.Terrain

    local att1 = Instance.new('Attachment')
    att1.Position = endPos
    att1.Archivable = false
    att1.Parent = workspace.Terrain

    local bolt = LightningBolt.new(att0, att1, segments)
    bolt.Color = LightningColor

    if params.HSVShift then
        bolt.Color = ParticleHandler.HSVShift(bolt.Color, params.HSVShift)
    end

    bolt.MinRadius = 0
    bolt.MaxRadius = 2.5
    bolt.PulseLength = 1.5
    bolt.PulseSpeed = 4
    bolt.Thickness = 0.6
    bolt.FadeLength = 0.25
    bolt.AnimationSpeed = 8

    if params.Info then
        for k, v in pairs(params.Info) do
            bolt[k] = v
        end
    end

    local function Destroy(dissipateTime, dissipateSpeed)
        if getmetatable(bolt) then
            bolt:DestroyDissipate(dissipateTime, dissipateSpeed)
        end
        att0:Destroy()
        att1:Destroy()
    end

    return bolt, Destroy
end

local function BlackFlashLightning(cf, options)
    if cf == nil then return end
    options = options or {}

    if typeof(cf) == 'Instance' and cf:IsA('BasePart') then
        cf = cf.CFrame
    end

    local trove = Trove.new()

    -- 4 crossing bolts
    for _ = 1, 4 do
        local x = RNG:NextNumber(12, 18) * (RNG:NextInteger(0, 1) == 0 and -1 or 1)
        local y = RNG:NextNumber(-8, 12)
        local z = RNG:NextNumber(12, 18) * (RNG:NextInteger(0, 1) == 0 and -1 or 1)
        local _, destroyFn = CreateLightningBolt({
            Start = (cf * CFrame.new(-x, -y, -z)).Position,
            End   = (cf * CFrame.new(x, y, z)).Position,
            Info  = {
                Thickness = 0.75, PulseLength = 4,
                PulseSpeed = 4, MaxRadius = 8, AnimationSpeed = 12,
            },
            HSVShift = options.HSVShift,
        })
        trove:Add(function() destroyFn() end)
    end

    -- 3 outward bolts
    for _ = 1, 3 do
        local x = RNG:NextNumber(18, 36) * (RNG:NextInteger(0, 1) == 0 and -1 or 1)
        local y = RNG:NextNumber(6, 12)
        local z = RNG:NextNumber(2, 12) * (RNG:NextInteger(0, 1) == 0 and -1 or 1)
        local _, destroyFn = CreateLightningBolt({
            Start = cf.Position,
            End   = (cf * CFrame.new(x, y, z)).Position,
            Info  = {
                Thickness = 1.75, MaxRadius = 16,
                PulseLength = 4, PulseSpeed = 12, AnimationSpeed = 64,
            },
            HSVShift = options.HSVShift,
        })
        trove:Add(function() destroyFn() end)
    end

    task.wait(1)
    trove:Destroy()
end

